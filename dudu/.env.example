# Dudu configuration — copy to .env and fill in. Never commit the real .env.

# Anthropic key for the Claude Agent SDK
ANTHROPIC_API_KEY=sk-ant-...

# Absolute path to the local clone of the brain repo Dudu reads/writes
DUDU_REPO_PATH=/repo

# GitHub token for git push + opening PRs (fine-grained: contents RW + pull-requests)
GITHUB_TOKEN=github_pat_...

# Optional: restrict Dudu to one group (JID like "12345-67890@g.us", or a substring
# of the group's subject/name). Leave empty to respond in any chat where mentioned.
DUDU_GROUP=

# Optional: the keyword that wakes Dudu in a group. Default: dudu
DUDU_TRIGGER=dudu

# Optional: model id. Default: claude-opus-4-8
DUDU_MODEL=claude-opus-4-8

# Optional: map WhatsApp numbers to member slugs so memory is attributed correctly
DUDU_MEMBERS_JSON={"972500000001":"dor","972500000002":"gidi","972500000003":"ohad"}

# --- POC / testing only (no dedicated number) ---
# Link Dudu to your EXISTING WhatsApp and let him answer your own messages
# (e.g. in the "Message Yourself" chat). Loop-protected. Turn OFF for real use.
DUDU_POC_SELF=false
# Which member your own messages are attributed to in POC self-mode.
DUDU_POC_MEMBER=dor
