{
  "_comment": "SDXL + IP-Adapter STYLE TRANSFER (copies the style of a reference image) + Canny ControlNet (locks the shape). The consistency workflow: style comes from a real image, not from prompt words. generate.mjs uploads asset.styleref -> node 31 and asset.control.image -> node 11.",
  "4": { "class_type": "CheckpointLoaderSimple", "inputs": { "ckpt_name": "sd_xl_base_1.0.safetensors" } },
  "30": { "class_type": "IPAdapterUnifiedLoader", "inputs": { "model": ["4", 0], "preset": "PLUS (high strength)" } },
  "31": { "class_type": "LoadImage", "inputs": { "image": "styleref.png" } },
  "32": {
    "class_type": "IPAdapter",
    "inputs": {
      "model": ["30", 0], "ipadapter": ["30", 1], "image": ["31", 0],
      "weight": 0.9, "start_at": 0.0, "end_at": 1.0, "weight_type": "style transfer"
    }
  },
  "6": { "class_type": "CLIPTextEncode", "inputs": { "text": "POSITIVE_PROMPT_PLACEHOLDER", "clip": ["4", 1] } },
  "7": { "class_type": "CLIPTextEncode", "inputs": { "text": "NEGATIVE_PROMPT_PLACEHOLDER", "clip": ["4", 1] } },
  "11": { "class_type": "LoadImage", "inputs": { "image": "control.png" } },
  "12": { "class_type": "Canny", "inputs": { "image": ["11", 0], "low_threshold": 0.3, "high_threshold": 0.7 } },
  "13": { "class_type": "ControlNetLoader", "inputs": { "control_net_name": "controlnet-canny-sdxl.safetensors" } },
  "14": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": ["6", 0], "negative": ["7", 0], "control_net": ["13", 0], "image": ["12", 0],
      "strength": 0.6, "start_percent": 0.0, "end_percent": 1.0
    }
  },
  "5": { "class_type": "EmptyLatentImage", "inputs": { "width": 1024, "height": 1024, "batch_size": 1 } },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0, "steps": 32, "cfg": 7.0, "sampler_name": "dpmpp_2m", "scheduler": "karras", "denoise": 1.0,
      "model": ["32", 0], "positive": ["14", 0], "negative": ["14", 1], "latent_image": ["5", 0]
    }
  },
  "8": { "class_type": "VAEDecode", "inputs": { "samples": ["3", 0], "vae": ["4", 2] } },
  "9": { "class_type": "SaveImage", "inputs": { "filename_prefix": "malabi", "images": ["8", 0] } }
}
