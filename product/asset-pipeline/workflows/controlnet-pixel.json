{
  "_comment": "SDXL + pixel-art-xl LoRA + Canny ControlNet. The control image (node 11) is rendered from the prototype's SVG layout (scripts/render-control.mjs) and uploaded by generate.mjs. Node 14 strength is the layout-adherence dial (1.0 strict, ~0.5 loose) — generate.mjs overrides it from asset.control.strength. Same prompt/size/sampler node ids as the other workflows.",
  "4": { "class_type": "CheckpointLoaderSimple", "inputs": { "ckpt_name": "sd_xl_base_1.0.safetensors" } },
  "10": {
    "class_type": "LoraLoader",
    "inputs": { "lora_name": "pixel-art-xl.safetensors", "strength_model": 1.0, "strength_clip": 1.0, "model": ["4", 0], "clip": ["4", 1] }
  },
  "6": { "class_type": "CLIPTextEncode", "inputs": { "text": "POSITIVE_PROMPT_PLACEHOLDER", "clip": ["10", 1] } },
  "7": { "class_type": "CLIPTextEncode", "inputs": { "text": "NEGATIVE_PROMPT_PLACEHOLDER", "clip": ["10", 1] } },
  "11": { "class_type": "LoadImage", "inputs": { "image": "lobby-control.png" } },
  "12": { "class_type": "Canny", "inputs": { "image": ["11", 0], "low_threshold": 0.4, "high_threshold": 0.8 } },
  "13": { "class_type": "ControlNetLoader", "inputs": { "control_net_name": "controlnet-canny-sdxl.safetensors" } },
  "14": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive": ["6", 0],
      "negative": ["7", 0],
      "control_net": ["13", 0],
      "image": ["12", 0],
      "strength": 0.8,
      "start_percent": 0.0,
      "end_percent": 1.0
    }
  },
  "5": { "class_type": "EmptyLatentImage", "inputs": { "width": 1344, "height": 768, "batch_size": 1 } },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0, "steps": 30, "cfg": 6.5, "sampler_name": "dpmpp_2m", "scheduler": "karras", "denoise": 1.0,
      "model": ["10", 0], "positive": ["14", 0], "negative": ["14", 1], "latent_image": ["5", 0]
    }
  },
  "8": { "class_type": "VAEDecode", "inputs": { "samples": ["3", 0], "vae": ["4", 2] } },
  "9": { "class_type": "SaveImage", "inputs": { "filename_prefix": "malabi", "images": ["8", 0] } }
}
