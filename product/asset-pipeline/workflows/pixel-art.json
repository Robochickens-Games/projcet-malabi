{
  "_comment": "SDXL txt2img + pixel-art-xl LoRA. Same node ids as transparent-painterly.json (6/7 prompts, 5 size, 3 sampler, 9 save) so generate.mjs overrides work unchanged; adds node 10 (LoraLoader) and rewires model/clip through it. Pair with scripts/pixelate.mjs for a crisp pixel grid.",
  "4": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "sd_xl_base_1.0.safetensors" }
  },
  "10": {
    "class_type": "LoraLoader",
    "inputs": {
      "lora_name": "pixel-art-xl.safetensors",
      "strength_model": 1.0,
      "strength_clip": 1.0,
      "model": ["4", 0],
      "clip": ["4", 1]
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "POSITIVE_PROMPT_PLACEHOLDER", "clip": ["10", 1] }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "NEGATIVE_PROMPT_PLACEHOLDER", "clip": ["10", 1] }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": { "width": 1024, "height": 1024, "batch_size": 1 }
  },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0,
      "steps": 30,
      "cfg": 6.5,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": ["10", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0]
    }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["3", 0], "vae": ["4", 2] }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": { "filename_prefix": "malabi", "images": ["8", 0] }
  }
}
