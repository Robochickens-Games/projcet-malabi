{
  "_comment": "SDXL + LayerDiffuse for NATIVE transparent (RGBA) generation. Node 20 patches the model for transparency; node 21 decodes the alpha. Use for isolated element sprites (arches, windows, props) — no background removal needed. Same prompt/size/sampler node ids as the other workflows so generate.mjs overrides work unchanged.",
  "4": { "class_type": "CheckpointLoaderSimple", "inputs": { "ckpt_name": "sd_xl_base_1.0.safetensors" } },
  "20": {
    "class_type": "LayeredDiffusionApply",
    "inputs": { "model": ["4", 0], "config": "SDXL, Attention Injection", "weight": 1.0 }
  },
  "6": { "class_type": "CLIPTextEncode", "inputs": { "text": "POSITIVE_PROMPT_PLACEHOLDER", "clip": ["4", 1] } },
  "7": { "class_type": "CLIPTextEncode", "inputs": { "text": "NEGATIVE_PROMPT_PLACEHOLDER", "clip": ["4", 1] } },
  "5": { "class_type": "EmptyLatentImage", "inputs": { "width": 832, "height": 1216, "batch_size": 1 } },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0, "steps": 30, "cfg": 6.5, "sampler_name": "dpmpp_2m", "scheduler": "karras", "denoise": 1.0,
      "model": ["20", 0], "positive": ["6", 0], "negative": ["7", 0], "latent_image": ["5", 0]
    }
  },
  "8": { "class_type": "VAEDecode", "inputs": { "samples": ["3", 0], "vae": ["4", 2] } },
  "21": {
    "class_type": "LayeredDiffusionDecodeRGBA",
    "inputs": { "samples": ["3", 0], "images": ["8", 0], "sd_version": "SDXL", "sub_batch_size": 16 }
  },
  "9": { "class_type": "SaveImage", "inputs": { "filename_prefix": "malabi", "images": ["21", 0] } }
}
